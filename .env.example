# OpenRouter — usado para Claude (texto + visão).
# Obtém em https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Modelo padrão (override apenas se quiseres mudar).
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Identificação no painel do OpenRouter (opcional).
OPENROUTER_APP_NAME=Bento CAPT
OPENROUTER_APP_URL=http://localhost:3000
